{
  "name": "mahjong",
  "version": "0.1.0",
  "private": true,
  "description": "Singaporean Mahjong — real-time multiplayer web game with virtual-coin top-up (Billplz).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace apps/server",
    "dev:web": "npm run dev --workspace apps/web",
    "build:engine": "npm run build --workspace packages/game-engine",
    "build:server": "npm run build --workspace apps/server",
    "build:web": "npm run build --workspace apps/web",
    "test": "npm run test --workspace packages/game-engine"
  },
  "engines": {
    "node": "20.x"
  }
}
