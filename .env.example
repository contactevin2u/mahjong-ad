# ─────────────────────────────────────────────────────────────
# Example environment variables. Copy to apps/server/.env and
# apps/web/.env.local and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# ===== apps/server (Render) =====
# PostgreSQL connection string (Render Postgres / Neon)
DATABASE_URL="postgresql://user:password@host:5432/mahjong?schema=public"

# Secret used to sign JWTs — generate a long random string
JWT_SECRET="change-me-to-a-long-random-secret"

# The public origin of the web app, used for CORS + redirect URLs
CLIENT_ORIGIN="http://localhost:3000"

# Public URL of THIS server (used to build the Billplz callback URL).
# Locally, expose via a tunnel (e.g. ngrok) and put that https URL here.
SERVER_PUBLIC_URL="http://localhost:4000"

# Port the server listens on (Render sets PORT automatically)
PORT="4000"

# ----- Billplz (Malaysia) -----
# Get these from the Billplz dashboard (use sandbox for testing).
BILLPLZ_BASE_URL="https://www.billplz-sandbox.com/api"
BILLPLZ_API_KEY="your-billplz-secret-api-key"
BILLPLZ_XSIGNATURE_KEY="your-billplz-x-signature-key"
BILLPLZ_COLLECTION_ID="your-billplz-collection-id"

# ===== apps/web (Vercel) =====
# Base URL of the server's REST API (no trailing slash)
NEXT_PUBLIC_API_URL="http://localhost:4000"
